# Copy to .env and fill in your own values. Never commit the real .env file.

# LLM provider for the natural-language MCP dialogue layer. Set exactly one;
# OPENAI_API_KEY wins if both are set. If neither is set, agents fall back to
# the offline deterministic template generator (used for all automated tests).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Bearer token required by the MCP servers when exposed beyond localhost
# (cloud deployment). Leave empty for local in-process runs.
MCP_AUTH_TOKEN=

# Gmail API OAuth (see docs/PRD_gmail_reporting.md for the one-time setup).
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=config/.gmail_token.json
