# Copy to .env and fill in your own values. Never commit the real .env file.

# Anthropic API key used for the natural-language MCP dialogue layer.
# If unset, agents fall back to the offline deterministic template generator.
ANTHROPIC_API_KEY=

# Gmail API OAuth (see docs/PRD_gmail_reporting.md for the one-time setup).
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=config/.gmail_token.json
